# ==============================================================================
#  .env.example — LFTG Platform v15.0.0
#
#  Copiez ce fichier en .env et remplissez les valeurs pour votre environnement.
# ==============================================================================

# ─── Base de données (PostgreSQL) ───────────────────────────────────────────
# URL de connexion complète pour Prisma
DATABASE_URL="postgresql://lftg:lftg_secret@localhost:5432/lftg_platform"

# ─── Cache (Redis) ──────────────────────────────────────────────────────────
# Utilisé pour le cache NestJS et les WebSockets
REDIS_HOST="localhost"
REDIS_PORT="6379"
# REDIS_URL="redis://localhost:6379" # Alternative si vous préférez une URL

# ─── Authentification (JWT) ─────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT. Utilisez une chaîne longue et aléatoire.
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Backend (NestJS) ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# URL du frontend pour les CORS et les liens dans les emails
FRONTEND_URL="http://localhost:3000"

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
# URL de l'API backend accessible depuis le navigateur du client
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ─── Stockage Fichiers (AWS S3) - Optionnel ─────────────────────────────────
# Requis pour le module `documents` (upload de fichiers)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET_NAME=""
# AWS_S3_REGION="eu-west-3"

# ─── Emails (Nodemailer) - Optionnel ────────────────────────────────────────
# Requis pour le module `email` (notifications, etc.)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
# SMTP_FROM="'LFTG Platform' <no-reply@lftg.fr>"

# ─── Push Notifications (Firebase) - Optionnel ──────────────────────────────
# Requis pour le module `push-fcm`
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Paiements (Stripe) - Optionnel ─────────────────────────────────────────
# Requis pour le module `ventes` si les paiements en ligne sont activés
# STRIPE_API_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Monitoring (Sentry) - Optionnel ────────────────────────────────────────
# SENTRY_DSN="https://..."
